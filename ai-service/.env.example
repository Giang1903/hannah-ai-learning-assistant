# ============================================================
# SE HANNAH - AI Service Environment Variables
# Copy file nay thanh ".env" va dien gia tri that
# KHONG commit file ".env" len Git
# ============================================================

# --- LLM Provider (chon 1 hoac ca 2 de du phong) ---
GOOGLE_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- LLM Model ---
LLM_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.3

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=se_hannah_documents

# --- JWT (PHAI TRUNG voi JWT_SECRET ben Backend Spring Boot) ---
JWT_SECRET=change_this_to_a_real_secret_key_min_32_chars
JWT_ALGORITHM=HS256

# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=8000

# --- CORS - domain cua Frontend ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Backend Spring Boot URL (neu AI Service can goi nguoc lai) ---
BACKEND_SERVICE_URL=http://localhost:8080/api

# --- RAG Config ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=4
