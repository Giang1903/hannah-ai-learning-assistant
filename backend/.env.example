# ============================================================
# SE HANNAH BACKEND - Environment Variables
# Copy file nay thanh ".env" va dien gia tri that
# KHONG commit file ".env" len Git
# ============================================================

# Database
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# JWT Secret (it nhat 256 bit, co the tao bang: openssl rand -base64 32)
JWT_SECRET=change_this_to_a_real_secret_key_min_32_chars

# AI Service (FastAPI) URL
AI_SERVICE_URL=http://localhost:8000

# CORS - domain cua Frontend
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload directory
UPLOAD_DIR=./uploads
